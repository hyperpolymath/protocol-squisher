package ephapax-ir-ffi

version = 1.1.0
authors = "Jonathan D.A. Jewell <j.d.a.jewell@open.ac.uk>"
license = "MPL-2.0"
brief = "Protocol Squisher IR - C FFI Library"

depends = base

sourcedir = "."
builddir = "build-ffi"
outputdir = "build-ffi/lib"

modules = Types
        , Compat
        , FFI

opts = "--total --cg refc"
