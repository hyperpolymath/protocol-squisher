package ephapax-ir

version = 1.1.0
authors = "Jonathan D.A. Jewell <j.d.a.jewell@open.ac.uk>"
license = "MPL-2.0"
brief = "Protocol Squisher Canonical IR with Linear Types"

depends = base

sourcedir = "."
builddir = "build"
outputdir = "build/exec"

modules = Types
        , Compat
        , TestSimple

executable = "ephapax-ir-test"
main = TestSimple

opts = "--total"
