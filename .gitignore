# RSR-compliant .gitignore

# OS & Editor
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/

# Build
/target/
/_build/
/build/
/dist/
/out/

# Dependencies
/node_modules/
/vendor/
/deps/
/.elixir_ls/

# Rust

# Julia
*.jl.cov
*.jl.mem
/Manifest.toml

# ReScript
/lib/bs/
/.bsb.lock

# Python (SaltStack only)
__pycache__/
*.py[cod]
.venv/

# Secrets
.env
.env.*
*.pem
*.key
secrets/

# Test/Coverage
/coverage/
htmlcov/

# Logs
*.log
/logs/

# Temp
/tmp/
*.tmp
*.bak

# Zig build artifacts (global — matches any depth)
.zig-cache/
zig-out/

# Local tooling artifacts
/tools/

# Generated runtime output (panic-attack, abduct, amuck)
/reports/
/runtime/

# Site build output (generated by ddraig-ssg)
/site/output/*.html

# PyO3 integration test venv
tests/pyo3-integration/.venv/
tests/pyo3-integration/target/
tests/pyo3-integration/.pytest_cache/
tests/pyo3-integration/__pycache__/
target/
node_modules/
_build/
deps/
.elixir_ls/
.cache/
build/
dist/
